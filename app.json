{
  "expo": {
    "name": "contra",
    "slug": "contra",
    "owner": "tajsingh15",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "contra",
    "userInterfaceStyle": "automatic",
    "ios": {
      "config": {
        "usesNonExemptEncryption": false
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.tajsingh.contraapp",
      "infoPlist": {
        "NSCameraUsageDescription": "Contra utilise la caméra pour prendre une photo de profil.",
        "NSPhotoLibraryUsageDescription": "Contra accède à ta galerie pour choisir une photo de profil.",
        "NSMicrophoneUsageDescription": "Contra utilise le micro pour les fonctionnalités audio."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2B3F52",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.tajsingh.contraapp",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "com.android.vending.BILLING"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2B3F52",
          "dark": {
            "backgroundColor": "#0E1926"
          }
        }
      ],
      "expo-localization",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Contra accède à ta galerie pour choisir une photo de profil.",
          "cameraPermission": "Contra utilise la caméra pour prendre une photo de profil."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b342b31e-7e0f-4758-9074-32a0b65078f0"
      }
    }
  }
}