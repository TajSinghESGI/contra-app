{
  "expo": {
    "name": "contra",
    "slug": "contra",
    "owner": "tajsingh15",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "contra",
    "userInterfaceStyle": "automatic",
    "ios": {
      "config": {
        "usesNonExemptEncryption": false
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.tajsingh.contraapp",
      "associatedDomains": ["applinks:contra-app.cloud"],
      "infoPlist": {
        "NSCameraUsageDescription": "Contra utilise la caméra pour prendre une photo de profil.",
        "NSPhotoLibraryUsageDescription": "Contra accède à ta galerie pour choisir une photo de profil.",
        "NSMicrophoneUsageDescription": "Contra utilise le micro pour les fonctionnalités audio.",
        "NSSpeechRecognitionUsageDescription": "Contra utilise la reconnaissance vocale pour transcrire tes arguments en texte."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2B3F52"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.tajsingh.contraapp",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "contra-app.cloud", "pathPrefix": "/share" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "RECORD_AUDIO",
        "com.android.vending.BILLING"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2B3F52",
          "dark": {
            "backgroundColor": "#0E1926"
          }
        }
      ],
      "expo-localization",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Contra accède à ta galerie pour choisir une photo de profil.",
          "cameraPermission": "Contra utilise la caméra pour prendre une photo de profil."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Contra utilise le micro pour débattre à la voix.",
          "speechRecognitionPermission": "Contra utilise la reconnaissance vocale pour transcrire tes arguments."
        }
      ],
      "expo-font",
      "expo-image",
      "expo-sharing",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b342b31e-7e0f-4758-9074-32a0b65078f0"
      }
    }
  }
}
